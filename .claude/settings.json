{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 60,
  "env": {
    "MAX_MCP_OUTPUT_TOKENS": "35000",
    "EDITOR": "nvim",
    "GIT_EDITOR": "nvim",
    "ENABLE_TOOL_SEARCH": "true"
  },
  "includeCoAuthoredBy": true,
  "permissions": {
    "allow": [
      "Bash(/usr/bin/osascript:*)",
      "Bash(terminal-notifier:*)",
      "Bash(grep:*)",
      "Bash(mcp:*)",
      "Bash(pwd:*)",
      "mcp__josh-notes__search_posts",
      "WebFetch(domain:www.joshbeckman.org)",
      "mcp__josh-beckman-status__get_status",
      "mcp__josh-beckman-status__get_current_time_of_day",
      "Bash(preview-md:*)",
      "mcp__josh-notes__get_post",
      "Bash(gh view-md:*)",
      "mcp__slack-mcp__get_messages",
      "mcp__slack-mcp__get_unreads",
      "mcp__slack-mcp__search_channels",
      "mcp__gworkspace-mcp__read_file",
      "mcp__gworkspace-mcp__search_drive",
      "mcp__fellow-mcp__search_meetings",
      "mcp__vault-mcp__vault_get_user_feed",
      "Bash(ls:*)",
      "Bash(gh extension:*)",
      "mcp__josh-notes__get_proverbs",
      "Bash(quick:*)",
      "Bash(pandoc:*)",
      "WebFetch(domain:arxiv.org)",
      "Bash(gh api:*)",
      "Bash(gh pr list:*)",
      "Bash(cat:*)",
      "Bash(git status:*)",
      "Bash(gh issue:*)",
      "Bash(/Users/joshbeckman/dotfiles/bin/humanity)",
      "Bash(nvim --headless -c 'Copilot status' -c 'qa!')",
      "Bash(nvim *)",
      "Skill(update-config)",
      "Bash(rtk git *)",
      "Bash(rtk read *)",
      "Bash(rtk ls *)",
      "Bash(rtk wc *)",
      "Bash(rtk ps *)",
      "Bash(rtk grep *)"
    ],
    "deny": [],
    "defaultMode": "auto",
    "additionalDirectories": [
      "~/Downloads",
      "/tmp"
    ]
  },
  "model": "opus",
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "INPUT=$(cat); echo \"$INPUT\" | ~/.claude/hooks/session-registry.sh permission; echo \"$INPUT\" | ~/.claude/hooks/attention.sh set_permission"
          }
        ]
      },
      {
        "matcher": "elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "INPUT=$(cat); echo \"$INPUT\" | ~/.claude/hooks/session-registry.sh question; echo \"$INPUT\" | ~/.claude/hooks/attention.sh set_question"
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-registry.sh idle"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "INPUT=$(cat); echo \"$INPUT\" | ~/.claude/hooks/session-registry.sh stopped; echo \"$INPUT\" | ~/.claude/hooks/attention.sh clear"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/skills-update.mjs",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/session-registry.sh start"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "INPUT=$(cat); echo \"$INPUT\" | ~/.claude/hooks/session-registry.sh end; echo \"$INPUT\" | ~/.claude/hooks/attention.sh clear"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/attention.sh clear"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "INPUT=$(cat); echo \"$INPUT\" | ~/.claude/hooks/session-registry.sh running; echo \"$INPUT\" | ~/.claude/hooks/attention.sh clear"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "theme": "light",
  "preferredNotifChannel": "terminal_bell",
  "feedbackSurveyState": {
    "lastShownTime": 1754147115362
  },
  "skipAutoPermissionPrompt": true
}
