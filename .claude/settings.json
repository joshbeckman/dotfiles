{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 60,
  "env": {
    "MAX_MCP_OUTPUT_TOKENS": "35000",
    "EDITOR": "nvim",
    "GIT_EDITOR": "nvim",
    "ENABLE_TOOL_SEARCH": "true"
  },
  "includeCoAuthoredBy": true,
  "permissions": {
    "allow": [
      "Bash(/usr/bin/osascript:*)",
      "Bash(terminal-notifier:*)",
      "Bash(grep:*)",
      "Bash(mcp:*)",
      "Bash(pwd:*)",
      "mcp__josh-notes__search_posts",
      "WebFetch(domain:www.joshbeckman.org)",
      "mcp__josh-beckman-status__get_status",
      "mcp__josh-beckman-status__get_current_time_of_day",
      "Bash(preview-md:*)",
      "mcp__josh-notes__get_post"
    ],
    "additionalDirectories": [
      "~/Downloads",
      "/tmp"
    ]
  },
  "model": "opus",
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "INPUT=$(cat); echo \"$INPUT\" | ~/.claude/hooks/session-registry.sh permission; echo \"$INPUT\" | ~/.claude/hooks/attention.sh set_permission"
          }
        ]
      },
      {
        "matcher": "elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "INPUT=$(cat); echo \"$INPUT\" | ~/.claude/hooks/session-registry.sh question; echo \"$INPUT\" | ~/.claude/hooks/attention.sh set_question"
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-registry.sh idle"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "INPUT=$(cat); echo \"$INPUT\" | ~/.claude/hooks/session-registry.sh stopped; echo \"$INPUT\" | ~/.claude/hooks/attention.sh clear"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/skills-update.mjs",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/session-registry.sh start"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "INPUT=$(cat); echo \"$INPUT\" | ~/.claude/hooks/session-registry.sh end; echo \"$INPUT\" | ~/.claude/hooks/attention.sh clear"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/attention.sh clear"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "INPUT=$(cat); echo \"$INPUT\" | ~/.claude/hooks/session-registry.sh running; echo \"$INPUT\" | ~/.claude/hooks/attention.sh clear"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "feedbackSurveyState": {
    "lastShownTime": 1754147115362
  }
}
