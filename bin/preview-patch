#!/bin/bash

if [[ "$1" == "-h" ]] || [[ "$1" == "--help" ]]; then
    echo "preview-patch - Preview a git patch/diff as HTML in your browser"
    echo ""
    echo "Usage: preview-patch [COMMIT]"
    echo "       git diff | preview-patch"
    echo "       git show HEAD | preview-patch"
    echo ""
    echo "With a commit argument, runs 'git show' on it."
    echo "Without arguments, reads a unified diff from stdin."
    exit 0
fi

timestamp=$(date +%Y%m%d_%H%M%S)
tmpfile="/tmp/preview-patch-${timestamp}-$$.html"

trap "sleep 5; rm -f '$tmpfile'" EXIT

remote_url=$(git remote get-url origin 2>/dev/null | sed -E 's/\.git$//; s#git@([^:]+):#https://\1/#')

if [[ $# -ge 1 ]]; then
    diff_input=$(git show "$@")
else
    diff_input=$(cat)
fi

if [[ -z "$diff_input" ]]; then
    echo "Error: no input provided." >&2
    exit 1
fi

body_html=$(echo "$diff_input" | awk -v remote="$remote_url" '
function esc(s) {
    gsub(/&/, "\\&amp;", s)
    gsub(/</, "\\&lt;", s)
    gsub(/>/, "\\&gt;", s)
    return s
}
BEGIN { in_diff = 0; header_done = 0 }
/^diff --git/ { in_diff = 1; if (!header_done) { print "</pre><pre>"; header_done = 1 } }
{
    if (!in_diff) {
        if (!header_started) { printf "<pre class=\"header\">"; header_started = 1 }
        if ($0 ~ /^commit /) {
            sha = $2
            if (remote != "" && sha != "") {
                printf "<span class=\"commit\">commit <a href=\"%s/commit/%s\">%s</a></span>\n", remote, sha, sha
            } else {
                printf "<span class=\"commit\">%s</span>\n", esc($0)
            }
        } else if ($0 ~ /^Author:/ || $0 ~ /^Date:/) {
            printf "<span class=\"meta\">%s</span>\n", esc($0)
        } else {
            print esc($0)
        }
    } else {
        if ($0 ~ /^diff --git/) {
            printf "<span class=\"file\">%s</span>\n", esc($0)
        } else if ($0 ~ /^index / || $0 ~ /^---/ || $0 ~ /^\+\+\+/) {
            printf "<span class=\"index\">%s</span>\n", esc($0)
        } else if ($0 ~ /^@@/) {
            printf "<span class=\"hunk\">%s</span>\n", esc($0)
        } else if ($0 ~ /^\+/) {
            printf "<span class=\"add\">%s</span>\n", esc($0)
        } else if ($0 ~ /^-/) {
            printf "<span class=\"del\">%s</span>\n", esc($0)
        } else {
            print esc($0)
        }
    }
}
END { print "</pre>" }')

cat > "$tmpfile" <<HTMLEOF
<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<title>Patch Preview</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
body {
    font-family: "IBM Plex Mono", monospace;
    font-size: 13px;
    line-height: 1.5;
    padding: 2ch;
    margin: 0;
    background: #fdf6e3;
    color: #657b83;
}
pre {
    white-space: pre-wrap;
    word-wrap: break-word;
    margin: 0;
}
.header {
    border-bottom: 1px solid #93a1a1;
    padding-bottom: 1ch;
    margin-bottom: 1ch;
}
.commit, .commit a { color: #b58900; font-weight: bold; }
.meta { color: #657b83; }
.file { color: #268bd2; font-weight: bold; }
.index { color: #93a1a1; }
.hunk { color: #6c71c4; }
.add { color: #859900; background: rgba(0,0,0,0.03); }
.del { color: #dc322f; background: rgba(0,0,0,0.03); }
@media (prefers-color-scheme: dark) {
    body { background: #002b36; color: #839496; }
    .header { border-color: #586e75; }
    .meta { color: #839496; }
    .index { color: #586e75; }
    .add { color: #859900; background: rgba(255,255,255,0.03); }
    .del { color: #dc322f; background: rgba(255,255,255,0.03); }
}
</style>
</head>
<body>
${body_html}
</body>
</html>
HTMLEOF

open "$tmpfile"
