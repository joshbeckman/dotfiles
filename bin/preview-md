#!/bin/bash

show_help() {
    echo "preview-md - Preview markdown as HTML in your browser"
    echo ""
    echo "Usage: preview-md [--watch[=SECONDS]] [--title TITLE] [FILE]"
    echo "       preview-md [--title TITLE] \"STRING\""
    echo "       command | preview-md [--title TITLE]"
    echo "       preview-md [--title TITLE] < file.md"
    echo ""
    echo "Reads markdown from stdin, a file, or a string argument and opens it as HTML in your browser."
    echo "Uses pandoc to convert GitHub Flavored Markdown to HTML."
    echo ""
    echo "Diagrams: \`\`\`mermaid and \`\`\`dot (or \`\`\`graphviz) fenced blocks render as inline SVG"
    echo "          via mermaid + viz-js loaded from jsdelivr (requires internet)."
    echo ""
    echo "Options:"
    echo "  --watch[=SECONDS]   Re-render on an interval (default 10s) until the source file is deleted."
    echo "                      Requires a FILE argument. Browser auto-refreshes via meta refresh."
    echo "  --title TITLE       Set the browser page title without adding a visible document title."
}

watch_interval=0
page_title=""
positional=()
while (($#)); do
    case "$1" in
        -h|--help) show_help; exit 0 ;;
        --watch) watch_interval=10 ;;
        --watch=*) watch_interval="${1#--watch=}" ;;
        --title)
            if [[ $# -lt 2 ]]; then
                echo "Error: --title requires a value." >&2
                exit 1
            fi
            page_title="$2"
            shift
            ;;
        --title=*) page_title="${1#--title=}" ;;
        --) shift; positional+=("$@"); break ;;
        *) positional+=("$1") ;;
    esac
    shift
done
set -- "${positional[@]}"

if ! [[ "$watch_interval" =~ ^[0-9]+$ ]]; then
    echo "Error: --watch interval must be a positive integer." >&2
    exit 1
fi

if ! command -v pandoc &> /dev/null; then
    echo "Error: pandoc is not installed." >&2
    echo "Please install pandoc to use this tool:" >&2
    echo "  macOS: brew install pandoc" >&2
    echo "  Ubuntu/Debian: sudo apt-get install pandoc" >&2
    echo "  Other: https://pandoc.org/installing.html" >&2
    exit 1
fi

timestamp=$(date +%Y%m%d_%H%M%S)
tmpfile="/tmp/preview-md-${timestamp}-$$.html"
tmpfile_raw="/tmp/preview-md-raw-${timestamp}-$$.html"
pandoc_args=(-f gfm -t html -s)
if [[ -n "$page_title" ]]; then
    pandoc_args+=(--metadata "pagetitle=$page_title")
fi

custom_styles='<base target="_blank"><link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Condensed:wght@400;600;700&family=IBM+Plex+Sans:ital,wght@0,100..700;1,100..700&display=swap" rel="stylesheet"><style>:root { --c-bg: #FFFFFF; --c-bg-alt: #f6f6f6; --c-text: #0D0D0D; --c-text-alt: #555; --c-link: #002FA7; --c-link-visited: #903465; --c-border: #d8d8d8; --c-red: #bd2024; --c-orange: #FF7900; --c-yellow: #FFCC00; --c-green: #237F52; } @media (prefers-color-scheme: dark) { :root { --c-bg: #0D0D0D; --c-bg-alt: #1b1b1b; --c-text: #FFFFFF; --c-text-alt: #c9c9c9; --c-link: #9bb8ff; --c-link-visited: #d8c5ff; --c-border: #3a3a3a; } } html, body { background: var(--c-bg); color: var(--c-text); } body { font-family: "IBM Plex Sans", sans-serif; line-height: 1.6; max-width: 70ch; margin: 2rem auto; padding: 1.5rem; } body:before, body:after { display:none; } h1, h2, h3, h4, h5, h6 { font-family: "IBM Plex Sans Condensed", "IBM Plex Sans", sans-serif; font-weight: 600; letter-spacing: 0.04em; line-height: 1.15; margin: 2rem 0 0.75rem; text-transform: uppercase; } a { color: var(--c-link); text-decoration-thickness: 0.08em; text-underline-offset: 0.16em; } a:visited { color: var(--c-link-visited); } a:hover { text-decoration-thickness: 0.14em; } :focus-visible { outline: 2px solid var(--c-orange); outline-offset: 2px; } code, pre { font-family: "Berkeley Mono", "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, monospace; } code { background: var(--c-bg-alt); border: 1px solid var(--c-border); border-radius: 0.2rem; padding: 0.05rem 0.25rem; } pre { background: var(--c-bg-alt); border: 1px solid var(--c-border); padding: 1rem; overflow-x: auto; } pre code { border: 0; padding: 0; } blockquote { border-left: 3px solid var(--c-border); color: var(--c-text-alt); margin-left: 0; padding-left: 1rem; } hr { border-color: var(--c-border); } table { border-collapse: collapse; } table, th, td { border-color: var(--c-border); } th, td { padding: 0.35rem 0.5rem; } th { background: var(--c-bg-alt); } img { max-width: 100%; height: auto; } .diagram-rendered { margin: 2rem 0; text-align: center; } .diagram-rendered svg { max-width: 100%; height: auto; } .diagram-rendered.graphviz { background: #FFFFFF; border-radius: 0.2rem; padding: 1rem; } .diagram-error { padding: 1rem; border: 1px solid var(--c-red); color: var(--c-red); font: 12px "Berkeley Mono", "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, monospace; white-space: pre-wrap; } .preview-md-badge { position: fixed; top: 1rem; right: 1rem; padding: 0.25rem 0.6rem; font: 11px/1.2 "Berkeley Mono", "IBM Plex Mono", ui-monospace, SFMono-Regular, Menlo, monospace; border-radius: 0.2rem; opacity: 0.9; background: var(--c-green); color: #FFFFFF; z-index: 9999; } @keyframes preview-md-stale { 0% { background: var(--c-green); color: #FFFFFF; } 66% { background: var(--c-yellow); color: #0D0D0D; } 100% { background: var(--c-red); color: #FFFFFF; } }</style>'

# Why a single-line inline ESM <script> rather than separate <script src> tags or multi-line:
# - pandoc gfm wraps `dot` blocks in <div class="sourceCode"><pre class="sourceCode dot">…spans…</pre></div>
#   while `mermaid` blocks get <pre class="mermaid"><code>…</code></pre>. Reading textContent on the <pre>
#   strips highlighting spans, so a single replacer handles both — we don't need mermaid auto-init
#   or graphviz HTMLWidget, both of which would miss the dot case.
# - The string is on one line because awk -v in the head-inject step rejects embedded newlines.
diagram_script='<script type="module">(async () => { const dark = window.matchMedia("(prefers-color-scheme: dark)").matches; const replaceWith = (node, html, kind) => { const w = document.createElement("div"); w.className = "diagram-rendered " + kind; w.innerHTML = html; (node.closest("div.sourceCode") || node.closest("pre") || node).replaceWith(w); }; const showErr = (node, err) => { const p = document.createElement("pre"); p.className = "diagram-error"; p.textContent = String(err && err.message || err); (node.closest("div.sourceCode") || node.closest("pre") || node).replaceWith(p); }; const mNodes = Array.from(document.querySelectorAll("pre.mermaid, pre.sourceCode.mermaid")); if (mNodes.length) { try { const { default: mermaid } = await import("https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs"); mermaid.initialize({ startOnLoad: false, theme: dark ? "dark" : "default", securityLevel: "loose" }); let i = 0; for (const n of mNodes) { try { const { svg } = await mermaid.render("mermaid-" + (i++), n.textContent.trim()); replaceWith(n, svg, "mermaid"); } catch (e) { showErr(n, e); } } } catch (e) { console.error("mermaid load failed", e); } } const dNodes = Array.from(document.querySelectorAll("pre.dot, pre.sourceCode.dot, pre.graphviz, pre.sourceCode.graphviz")); if (dNodes.length) { try { const { instance } = await import("https://cdn.jsdelivr.net/npm/@viz-js/viz/lib/viz-standalone.mjs"); const viz = await instance(); for (const n of dNodes) { try { replaceWith(n, viz.renderSVGElement(n.textContent.trim()).outerHTML, "graphviz"); } catch (e) { showErr(n, e); } } } catch (e) { console.error("graphviz load failed", e); } } })();</script>'

head_inject="${custom_styles}${diagram_script}"
if (( watch_interval > 0 )); then
    if [[ $# -ne 1 || ! -f "$1" ]]; then
        echo "Error: --watch requires a FILE argument that exists." >&2
        exit 1
    fi
    head_inject="${custom_styles}${diagram_script}<meta http-equiv=\"refresh\" content=\"${watch_interval}\">"
fi

render() {
    local badge=""
    if (( watch_interval > 0 )); then
        local fade=$(( watch_interval * 3 / 2 ))
        (( fade < 1 )) && fade=1
        local ts
        ts=$(date +"%H:%M:%S")
        badge="<div class=\"preview-md-badge\" style=\"animation: preview-md-stale ${fade}s forwards;\">Rendered ${ts} · every ${watch_interval}s</div>"
    fi
    awk -v styles="$head_inject" -v badge="$badge" '
        /<\/head>/ {print styles}
        badge != "" && /<body/ && !injected {print; print badge; injected=1; next}
        {print}
    ' "$tmpfile_raw" > "$tmpfile"
}

if [[ $# -eq 1 ]]; then
    if [[ -f "$1" ]]; then
        pandoc "${pandoc_args[@]}" "$1" > "$tmpfile_raw"
    else
        echo "$1" | pandoc "${pandoc_args[@]}" > "$tmpfile_raw"
    fi
else
    pandoc "${pandoc_args[@]}" > "$tmpfile_raw"
fi
render

open "$tmpfile"

if (( watch_interval > 0 )); then
    source_file="$1"
    (
        trap "rm -f '$tmpfile' '$tmpfile_raw'; kill 0 2>/dev/null; exit 0" TERM INT EXIT
        while :; do
            sleep "$watch_interval" &
            wait $!
            [[ -f "$source_file" ]] || break
            pandoc "${pandoc_args[@]}" "$source_file" > "$tmpfile_raw" 2>/dev/null || continue
            render
        done
    ) &
    watcher_pid=$!
    disown
    echo "Watching $source_file (interval: ${watch_interval}s, pid: ${watcher_pid})." >&2
    echo "Stop with: kill ${watcher_pid}  (or delete the source file)" >&2
    exit 0
fi

# Non-watch mode: clean up tmpfiles shortly after the browser has opened them.
trap "sleep 5; rm -f '$tmpfile' '$tmpfile_raw'" EXIT
