#!/bin/bash

show_help() {
    echo "preview-md - Preview markdown as HTML in your browser"
    echo ""
    echo "Usage: preview-md [--watch[=SECONDS]] [FILE]"
    echo "       preview-md \"STRING\""
    echo "       command | preview-md"
    echo "       preview-md < file.md"
    echo ""
    echo "Reads markdown from stdin, a file, or a string argument and opens it as HTML in your browser."
    echo "Uses pandoc to convert GitHub Flavored Markdown to HTML."
    echo ""
    echo "Options:"
    echo "  --watch[=SECONDS]   Re-render on an interval (default 10s) until the source file is deleted."
    echo "                      Requires a FILE argument. Browser auto-refreshes via meta refresh."
}

watch_interval=0
positional=()
for arg in "$@"; do
    case "$arg" in
        -h|--help) show_help; exit 0 ;;
        --watch) watch_interval=10 ;;
        --watch=*) watch_interval="${arg#--watch=}" ;;
        *) positional+=("$arg") ;;
    esac
done
set -- "${positional[@]}"

if ! [[ "$watch_interval" =~ ^[0-9]+$ ]]; then
    echo "Error: --watch interval must be a positive integer." >&2
    exit 1
fi

if ! command -v pandoc &> /dev/null; then
    echo "Error: pandoc is not installed." >&2
    echo "Please install pandoc to use this tool:" >&2
    echo "  macOS: brew install pandoc" >&2
    echo "  Ubuntu/Debian: sudo apt-get install pandoc" >&2
    echo "  Other: https://pandoc.org/installing.html" >&2
    exit 1
fi

timestamp=$(date +%Y%m%d_%H%M%S)
tmpfile="/tmp/preview-md-${timestamp}-$$.html"
tmpfile_raw="/tmp/preview-md-raw-${timestamp}-$$.html"

custom_styles='<base target="_blank"><link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:ital,wght@0,100..700;1,100..700&display=swap" rel="stylesheet"><style>body { font-family: "IBM Plex Sans", sans-serif; max-width: 80ch; margin: 2ch auto; padding: 2ch; } body:before, body:after { display:none; } h1, h2, h3, h4, h5, h6 { margin: 3ch 0; } @media (prefers-color-scheme: dark) { html, body { background: #1a1a2e; color: #e0e0e0; } a { color: #6ea8fe; } a:visited { color: #b4a0ff; } code { background: #2a2a3e; } pre { background: #2a2a3e; padding: 1ch; overflow-x: auto; } blockquote { border-left: 3px solid #444; padding-left: 1ch; color: #aaa; } hr { border-color: #444; } table, th, td { border-color: #444; } th { background: #2a2a3e; } } .preview-md-badge { position: fixed; top: 1ch; right: 1ch; padding: 0.3ch 0.8ch; font: 11px/1.2 ui-monospace, SFMono-Regular, Menlo, monospace; border-radius: 3px; opacity: 0.85; background: #2ecc71; color: #0a3d0a; z-index: 9999; } @keyframes preview-md-stale { 0% { background: #2ecc71; color: #0a3d0a; } 66% { background: #f1c40f; color: #3a2a00; } 100% { background: #e74c3c; color: #fff; } }</style>'

head_inject="$custom_styles"
if (( watch_interval > 0 )); then
    if [[ $# -ne 1 || ! -f "$1" ]]; then
        echo "Error: --watch requires a FILE argument that exists." >&2
        exit 1
    fi
    head_inject="${custom_styles}<meta http-equiv=\"refresh\" content=\"${watch_interval}\">"
fi

render() {
    local badge=""
    if (( watch_interval > 0 )); then
        local fade=$(( watch_interval * 3 / 2 ))
        (( fade < 1 )) && fade=1
        local ts
        ts=$(date +"%H:%M:%S")
        badge="<div class=\"preview-md-badge\" style=\"animation: preview-md-stale ${fade}s forwards;\">Rendered ${ts} · every ${watch_interval}s</div>"
    fi
    awk -v styles="$head_inject" -v badge="$badge" '
        /<\/head>/ {print styles}
        badge != "" && /<body/ && !injected {print; print badge; injected=1; next}
        {print}
    ' "$tmpfile_raw" > "$tmpfile"
}

if [[ $# -eq 1 ]]; then
    if [[ -f "$1" ]]; then
        pandoc -f gfm -t html -s "$1" > "$tmpfile_raw"
    else
        echo "$1" | pandoc -f gfm -t html -s > "$tmpfile_raw"
    fi
else
    pandoc -f gfm -t html -s > "$tmpfile_raw"
fi
render

open "$tmpfile"

if (( watch_interval > 0 )); then
    source_file="$1"
    (
        trap "rm -f '$tmpfile' '$tmpfile_raw'; kill 0 2>/dev/null; exit 0" TERM INT EXIT
        while :; do
            sleep "$watch_interval" &
            wait $!
            [[ -f "$source_file" ]] || break
            pandoc -f gfm -t html -s "$source_file" > "$tmpfile_raw" 2>/dev/null || continue
            render
        done
    ) &
    watcher_pid=$!
    disown
    echo "Watching $source_file (interval: ${watch_interval}s, pid: ${watcher_pid})." >&2
    echo "Stop with: kill ${watcher_pid}  (or delete the source file)" >&2
    exit 0
fi

# Non-watch mode: clean up tmpfiles shortly after the browser has opened them.
trap "sleep 5; rm -f '$tmpfile' '$tmpfile_raw'" EXIT
